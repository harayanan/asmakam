---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const siteData = yaml.load(readFileSync('src/data/site.yaml', 'utf8')) as Record<string, any>;
---

<BaseLayout title="Contact | Asmakam Life University" description="Get in touch with Asmakam Life University.">
  <Header />
  <main>
    <!-- Page Hero -->
    <section class="relative py-24 md:py-28 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=1920&q=80"
          alt=""
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-forest/85 via-forest/70 to-leaf/60"></div>
      </div>
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white font-bold mb-4 animate-fade-in-up drop-shadow-lg">Get in Touch</h1>
        <p class="font-body text-lg text-green-100 max-w-2xl mx-auto animate-fade-in-up delay-200">
          We'd love to hear from you. Reach out to learn more about our programs and community.
        </p>
      </div>
    </section>

    <section class="section-padding bg-cream">
      <div class="container-narrow mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div class="animate-fade-in-left">
            <h2 class="font-heading text-2xl text-forest font-bold mb-8">Contact Information</h2>

            <div class="space-y-6">
              <!-- Phone -->
              <div class="flex items-start gap-4 group">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-forest to-leaf flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-body font-semibold text-text-primary">Phone</h3>
                  <a href="tel:+917723837600" class="font-body text-leaf hover:text-forest transition-colors text-lg">
                    {siteData.phone}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4 group">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-forest to-leaf flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-body font-semibold text-text-primary">Email</h3>
                  <a href={`mailto:${siteData.email}`} class="font-body text-leaf hover:text-forest transition-colors">
                    {siteData.email}
                  </a>
                </div>
              </div>

              <!-- Location -->
              <div class="flex items-start gap-4 group">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-forest to-leaf flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-body font-semibold text-text-primary">Address</h3>
                  <p class="font-body text-text-muted">{siteData.address}</p>
                  <p class="font-body text-sm text-text-muted mt-1">15-acre permaculture food forest campus</p>
                </div>
              </div>

              <!-- Website -->
              <div class="flex items-start gap-4 group">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-forest to-leaf flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-body font-semibold text-text-primary">Website</h3>
                  <a href={siteData.website} target="_blank" rel="noopener" class="font-body text-leaf hover:text-forest transition-colors">
                    www.asmakam.org
                  </a>
                </div>
              </div>

              <!-- YouTube -->
              <div class="flex items-start gap-4 group">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-forest to-leaf flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-body font-semibold text-text-primary">YouTube</h3>
                  <a href={siteData.youtube} target="_blank" rel="noopener" class="font-body text-leaf hover:text-forest transition-colors block">
                    Award Winning Short Film
                  </a>
                  <a href={siteData.ecoHouseVideo} target="_blank" rel="noopener" class="font-body text-leaf hover:text-forest transition-colors block mt-1">
                    Asmakam Eco Natural House
                  </a>
                </div>
              </div>
            </div>

            <!-- Cotfoo -->
            <div class="mt-10 p-6 bg-white rounded-2xl border border-gray-100 shadow-md hover:shadow-lg transition-shadow">
              <h3 class="font-heading text-lg font-semibold text-forest mb-2">{siteData.cotfoo.name} - {siteData.cotfoo.fullName}</h3>
              <p class="font-body text-sm text-text-muted mb-3">{siteData.cotfoo.description}</p>
              <a href={siteData.cotfoo.website} target="_blank" rel="noopener" class="font-body text-sm text-leaf hover:text-forest font-medium transition-colors">
                Visit Cotfoo &rarr;
              </a>
            </div>
          </div>

          <!-- Google Maps -->
          <div class="animate-fade-in-right">
            <h2 class="font-heading text-2xl text-forest font-bold mb-6">Find Us</h2>
            <div class="rounded-2xl overflow-hidden shadow-xl">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3681.5!2d75.85!3d22.65!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjLCsDM5JzAwLjAiTiA3NcKwNTEnMDAuMCJF!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin&q=Asmakam+Life+University+Indore"
                width="100%"
                height="400"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Asmakam Life University Location"
              ></iframe>
            </div>
            <p class="font-body text-sm text-text-muted mt-4">
              {siteData.address}
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
