---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Pillars from '../components/Pillars.astro';
import ParadigmShift from '../components/ParadigmShift.astro';
import ContactSection from '../components/ContactSection.astro';
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const programsData = yaml.load(readFileSync('src/data/programs.yaml', 'utf8')) as Record<string, any>;
const pillarsData = yaml.load(readFileSync('src/data/pillars.yaml', 'utf8')) as Record<string, any>;

const iconMap: Record<string, string> = {
  home: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  globe: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  sun: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  compass: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
  mountain: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4-4 4 4 4-8 4 8M4 20h16"/></svg>`,
  briefcase: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
};
---

<BaseLayout title="Programs | Asmakam Life University" description="Explore our programs and experiences in sustainability, wellness and lifelong learning.">
  <Header />
  <main>
    <!-- Page Hero -->
    <section class="bg-gradient-to-br from-forest to-leaf py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-heading text-4xl md:text-5xl text-white font-bold mb-4">Programs & Experiences</h1>
        <p class="font-body text-lg text-green-100 max-w-2xl mx-auto">
          {programsData.intro}
        </p>
      </div>
    </section>

    <!-- Three Pillars (detailed) -->
    <section class="section-padding bg-cream">
      <div class="container-wide mx-auto">
        <div class="text-center mb-16">
          <h2 class="section-title">{pillarsData.title}</h2>
        </div>

        <div class="space-y-12">
          {pillarsData.pillars.map((pillar: any, i: number) => (
            <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 items-center ${i % 2 === 1 ? 'lg:direction-rtl' : ''}`}>
              <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
                <h3 class="font-heading text-3xl font-bold text-forest mb-4">{pillar.name}</h3>
                <p class="font-body text-lg text-text-muted leading-relaxed mb-6">{pillar.description}</p>
                <ul class="space-y-2">
                  {pillar.details.map((detail: string) => (
                    <li class="flex items-start gap-3 font-body text-text-muted">
                      <svg class="w-5 h-5 text-lime shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
              <div class={`bg-gradient-to-br from-forest/10 to-lime/10 rounded-3xl aspect-[4/3] flex items-center justify-center ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
                <span class="font-heading text-6xl text-forest/20">{pillar.name.charAt(0)}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Program Types -->
    <section class="section-padding bg-white">
      <div class="container-wide mx-auto">
        <div class="text-center mb-16">
          <h2 class="section-title">How to Experience ALU</h2>
          <p class="section-subtitle mx-auto mt-4">
            Multiple ways to engage with our programs and community
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {programsData.programTypes.map((program: any) => (
            <div class="card p-6 border border-gray-100 hover:border-lime/30 group">
              <div class="text-leaf group-hover:text-forest transition-colors mb-4">
                <Fragment set:html={iconMap[program.icon] || ''} />
              </div>
              <h3 class="font-heading text-xl font-semibold text-text-primary mb-2">
                {program.name}
              </h3>
              <p class="font-body text-sm text-text-muted leading-relaxed">
                {program.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Special Programs -->
    <section class="section-padding bg-sand">
      <div class="container-wide mx-auto">
        <div class="text-center mb-12">
          <h2 class="section-title">Special Programs</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {programsData.specialPrograms.map((program: any) => (
            <div class="card p-8 border border-gray-100">
              <h3 class="font-heading text-xl font-semibold text-forest mb-3">{program.name}</h3>
              <p class="font-body text-text-muted leading-relaxed">{program.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <ParadigmShift />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
