---
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const siteData = yaml.load(readFileSync('src/data/site.yaml', 'utf8')) as Record<string, any>;
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1920&q=80"
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-forest/85 via-forest/70 to-leaf/60"></div>
  </div>

  <!-- Floating decorative blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-64 h-64 bg-lime/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 bg-gold/10 rounded-full blur-3xl animate-float-delayed"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/5 rounded-full blur-3xl"></div>
    <!-- Spinning decorative ring -->
    <div class="absolute top-10 right-20 w-32 h-32 border border-white/10 rounded-full animate-gentle-spin hidden md:block"></div>
    <div class="absolute bottom-32 left-20 w-20 h-20 border border-lime/15 rounded-full animate-gentle-spin hidden md:block"></div>
  </div>

  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 lg:py-40 relative z-10">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Tagline -->
      <h1 class="font-heading text-4xl md:text-5xl lg:text-7xl text-white font-bold mb-6 leading-tight animate-fade-in-up drop-shadow-lg">
        {siteData.tagline}
      </h1>

      <!-- Subtitle -->
      <p class="font-body text-lg md:text-xl lg:text-2xl text-green-100 mb-8 max-w-2xl mx-auto leading-relaxed animate-fade-in-up delay-200">
        {siteData.subtitle}
      </p>

      <!-- Divider line -->
      <div class="w-24 h-0.5 bg-gradient-to-r from-transparent via-lime to-transparent mx-auto mb-8 animate-fade-in-up delay-300"></div>

      <!-- Motto -->
      <p class="font-body text-sm md:text-base text-lime/90 tracking-[0.3em] uppercase mb-12 animate-fade-in-up delay-300">
        {siteData.motto}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up delay-400">
        <a href="/programs" class="inline-block bg-white text-forest font-body font-semibold px-10 py-4 rounded-full hover:bg-lime hover:text-white transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1">
          Explore Programs
        </a>
        <a href="/about" class="inline-block border-2 border-white/80 text-white font-body font-semibold px-10 py-4 rounded-full hover:bg-white/15 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1">
          Our Story
        </a>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60C240 100 480 20 720 60C960 100 1200 20 1440 60V120H0V60Z" fill="#FAFAF5" opacity="0.5"/>
      <path d="M0 80C360 120 720 40 1080 80C1260 95 1350 90 1440 80V120H0V80Z" fill="#FAFAF5"/>
    </svg>
  </div>
</section>
