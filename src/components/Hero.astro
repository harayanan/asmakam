---
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const siteData = yaml.load(readFileSync('src/data/site.yaml', 'utf8')) as Record<string, any>;
---

<section class="relative bg-gradient-to-br from-forest via-leaf to-lime overflow-hidden">
  <!-- Decorative pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 left-10 w-32 h-32 rounded-full bg-white/20"></div>
    <div class="absolute bottom-20 right-20 w-48 h-48 rounded-full bg-white/10"></div>
    <div class="absolute top-1/2 left-1/3 w-24 h-24 rounded-full bg-white/15"></div>
  </div>

  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 lg:py-40 relative z-10">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Logo -->
      <img
        src="/images/logo.png"
        alt="Asmakam - OURS"
        class="h-28 md:h-40 lg:h-48 w-auto mx-auto mb-8 drop-shadow-lg"
      />

      <!-- Tagline -->
      <h1 class="font-heading text-3xl md:text-5xl lg:text-6xl text-white font-bold mb-6 leading-tight">
        {siteData.tagline}
      </h1>

      <!-- Subtitle -->
      <p class="font-body text-lg md:text-xl lg:text-2xl text-green-100 mb-8 max-w-2xl mx-auto leading-relaxed">
        {siteData.subtitle}
      </p>

      <!-- Motto -->
      <p class="font-body text-sm md:text-base text-green-200 tracking-widest uppercase mb-10">
        {siteData.motto}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/programs" class="inline-block bg-white text-forest font-body font-semibold px-8 py-3 rounded-full hover:bg-sand transition-colors duration-300">
          Explore Programs
        </a>
        <a href="/about" class="inline-block border-2 border-white text-white font-body font-semibold px-8 py-3 rounded-full hover:bg-white/10 transition-colors duration-300">
          Our Story
        </a>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 30C360 60 720 0 1080 30C1260 45 1350 40 1440 30V60H0V30Z" fill="#FAFAF5"/>
    </svg>
  </div>
</section>
