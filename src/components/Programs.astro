---
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const programsData = yaml.load(readFileSync('src/data/programs.yaml', 'utf8')) as Record<string, any>;

const iconMap: Record<string, string> = {
  home: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  globe: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  sun: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  compass: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
  mountain: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4-4 4 4 4-8 4 8M4 20h16"/></svg>`,
  briefcase: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
};

const gradientColors = [
  'from-forest/10 to-lime/5',
  'from-blue-500/10 to-cyan-400/5',
  'from-gold/10 to-amber-300/5',
  'from-plum/10 to-purple-300/5',
  'from-saffron/10 to-orange-300/5',
  'from-earth/10 to-amber-700/5',
];
---

<section class="section-padding bg-white">
  <div class="container-wide mx-auto">
    <div class="text-center mb-16 animate-fade-in-up">
      <p class="font-body text-sm tracking-[0.2em] uppercase text-leaf mb-3">What We Offer</p>
      <h2 class="section-title">Programs & Experiences</h2>
      <p class="section-subtitle mx-auto mt-4">
        Short term and long term residential and online programs focusing on sustainability, wellness and life learning.
      </p>
      <div class="w-16 h-1 bg-gradient-to-r from-forest to-lime mx-auto mt-6 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {programsData.programTypes.map((program: any, i: number) => (
        <div class={`group card p-7 border border-gray-100 hover:border-lime/30 bg-gradient-to-br ${gradientColors[i]} animate-fade-in-up delay-${Math.min((i + 1) * 100, 500)}`}>
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-forest to-leaf text-white flex items-center justify-center mb-5 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-forest/20 transition-all duration-500">
            <Fragment set:html={iconMap[program.icon] || ''} />
          </div>
          <h3 class="font-heading text-xl font-semibold text-text-primary mb-2 group-hover:text-forest transition-colors">
            {program.name}
          </h3>
          <p class="font-body text-sm text-text-muted leading-relaxed">
            {program.description}
          </p>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a href="/programs" class="btn-primary">
        View All Programs
      </a>
    </div>
  </div>
</section>
