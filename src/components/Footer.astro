---
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const siteData = yaml.load(readFileSync('src/data/site.yaml', 'utf8')) as Record<string, any>;
const navData = yaml.load(readFileSync('src/data/navigation.yaml', 'utf8')) as {
  links: { label: string; href: string }[];
};
---

<footer class="bg-forest text-white">
  <div class="container-wide mx-auto section-padding pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.png" alt="Asmakam" class="h-12 w-auto brightness-200" />
          <div>
            <span class="font-heading text-xl font-bold block">Asmakam</span>
            <span class="font-body text-sm text-green-200 block">Life University</span>
          </div>
        </div>
        <p class="font-body text-green-100 text-sm leading-relaxed mb-4">
          {siteData.tagline}
        </p>
        <p class="font-body text-green-200 text-xs">
          {siteData.motto}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-4">Quick Links</h3>
        <nav class="flex flex-col gap-2">
          {navData.links.map((link) => (
            <a
              href={link.href}
              class="font-body text-sm text-green-100 hover:text-white transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact & Links -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-4">Connect</h3>
        <div class="flex flex-col gap-3 font-body text-sm text-green-100">
          <a href={`mailto:${siteData.email}`} class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {siteData.email}
          </a>
          <a href={siteData.website} class="hover:text-white transition-colors flex items-center gap-2" target="_blank" rel="noopener">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            www.asmakam.org
          </a>
          <a href={siteData.youtube} class="hover:text-white transition-colors flex items-center gap-2" target="_blank" rel="noopener">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            YouTube
          </a>
          <div class="flex items-start gap-2 mt-1 text-green-200">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{siteData.address}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-green-800 pt-8 text-center">
      <p class="font-body text-sm text-green-200">
        &copy; {new Date().getFullYear()} Asmakam Life University. Founded {siteData.founded}.
      </p>
    </div>
  </div>
</footer>
