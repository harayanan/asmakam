---
interface Props {
  title: string;
  description?: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card p-6 border border-gray-100 flex flex-col h-full">
  <div class="flex-1">
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs font-body font-medium text-leaf bg-green-50 px-2 py-0.5 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
    <h3 class="font-heading text-xl font-semibold text-text-primary mb-2 hover:text-forest transition-colors">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
    {description && (
      <p class="font-body text-sm text-text-muted leading-relaxed mb-4">
        {description}
      </p>
    )}
  </div>
  <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-50">
    <time class="font-body text-xs text-text-muted" datetime={date.toISOString()}>
      {formattedDate}
    </time>
    <a href={`/blog/${slug}`} class="font-body text-sm text-leaf hover:text-forest font-medium transition-colors">
      Read more &rarr;
    </a>
  </div>
</article>
