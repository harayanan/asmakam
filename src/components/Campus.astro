---
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const campusData = yaml.load(readFileSync('src/data/campus.yaml', 'utf8')) as Record<string, any>;
---

<section class="section-padding bg-cream">
  <div class="container-wide mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div>
        <h2 class="section-title mb-6">{campusData.title}</h2>
        <p class="font-body text-lg text-text-muted leading-relaxed mb-6">
          {campusData.description}
        </p>
        <p class="font-body text-text-muted leading-relaxed mb-8">
          {campusData.infrastructure}
        </p>
        <div class="flex flex-wrap gap-3">
          {campusData.features.map((feature: string) => (
            <span class="font-body text-sm bg-forest/10 text-forest px-4 py-2 rounded-full">
              {feature}
            </span>
          ))}
        </div>
      </div>

      <!-- Image placeholder with decorative styling -->
      <div class="relative">
        <div class="bg-gradient-to-br from-forest/20 to-lime/20 rounded-3xl aspect-[4/3] flex items-center justify-center overflow-hidden">
          <div class="text-center p-8">
            <svg class="w-16 h-16 text-forest/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
            </svg>
            <p class="font-body text-forest/60 text-sm">
              Campus in the Food Forest<br/>
              <span class="text-xs text-forest/40">{campusData.location}</span>
            </p>
          </div>
        </div>
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-lime/20 rounded-full -z-10"></div>
        <div class="absolute -top-4 -left-4 w-16 h-16 bg-gold/20 rounded-full -z-10"></div>
      </div>
    </div>
  </div>
</section>
