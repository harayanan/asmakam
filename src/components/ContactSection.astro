---
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const siteData = yaml.load(readFileSync('src/data/site.yaml', 'utf8')) as Record<string, any>;
---

<section class="relative py-24 md:py-32 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/campus-peacock.png"
      alt=""
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-forest/90 to-leaf/80"></div>
  </div>

  <!-- Floating decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-10 left-[10%] w-40 h-40 bg-white/5 rounded-full blur-2xl animate-float"></div>
    <div class="absolute bottom-10 right-[10%] w-60 h-60 bg-lime/10 rounded-full blur-3xl animate-float-delayed"></div>
  </div>

  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-heading text-3xl md:text-5xl text-white font-bold mb-6 animate-fade-in-up drop-shadow-lg">
        Begin Your Journey
      </h2>
      <p class="font-body text-lg md:text-xl text-green-100 mb-10 leading-relaxed animate-fade-in-up delay-200">
        Discover your essence in harmony with Self, Society and the Universe.
        Connect with us to learn more about our programs and experiences.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up delay-300">
        <a href="/contact" class="inline-block bg-white text-forest font-body font-semibold px-10 py-4 rounded-full hover:bg-lime hover:text-white transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1">
          Get in Touch
        </a>
        <a href={siteData.youtube} target="_blank" rel="noopener" class="inline-block border-2 border-white/80 text-white font-body font-semibold px-10 py-4 rounded-full hover:bg-white/15 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1">
          Watch Our Story
        </a>
      </div>
    </div>
  </div>
</section>
