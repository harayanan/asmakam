---
interface Props {
  title: string;
  description?: string;
  date: Date;
  endDate?: Date;
  location?: string;
  slug: string;
  registrationLink?: string;
}

const { title, description, date, endDate, location, slug, registrationLink } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedEndDate = endDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="card p-6 border border-gray-100 flex flex-col h-full">
  <div class="flex-1">
    <div class="flex items-start gap-4 mb-4">
      <div class="shrink-0 bg-saffron/10 text-saffron rounded-xl p-3 text-center min-w-[60px]">
        <span class="block font-heading text-2xl font-bold leading-none">
          {date.getDate()}
        </span>
        <span class="block font-body text-xs uppercase mt-1">
          {date.toLocaleDateString('en-US', { month: 'short' })}
        </span>
      </div>
      <div>
        <h3 class="font-heading text-xl font-semibold text-text-primary">
          {title}
        </h3>
        {location && (
          <p class="font-body text-sm text-text-muted mt-1">{location}</p>
        )}
      </div>
    </div>
    {description && (
      <p class="font-body text-sm text-text-muted leading-relaxed">
        {description}
      </p>
    )}
  </div>
  <div class="flex items-center gap-4 mt-4 pt-4 border-t border-gray-50">
    <time class="font-body text-xs text-text-muted" datetime={date.toISOString()}>
      {formattedDate}{formattedEndDate ? ` - ${formattedEndDate}` : ''}
    </time>
    {registrationLink && (
      <a
        href={registrationLink}
        class="font-body text-sm text-saffron hover:text-orange-700 font-medium transition-colors ml-auto"
        target="_blank"
        rel="noopener"
      >
        Register &rarr;
      </a>
    )}
  </div>
</article>
