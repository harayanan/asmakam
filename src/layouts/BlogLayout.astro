---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

const { title, description, date, author, image, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | Asmakam Life University`} description={description} image={image}>
  <Header />
  <main class="flex-1">
    <article class="section-padding">
      <div class="container-narrow max-w-3xl">
        <header class="mb-12">
          {tags && tags.length > 0 && (
            <div class="flex gap-2 mb-4">
              {tags.map((tag) => (
                <span class="text-sm font-body font-medium text-leaf bg-green-50 px-3 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )}
          <h1 class="font-heading text-4xl md:text-5xl text-forest mb-4">{title}</h1>
          <div class="flex items-center gap-4 text-text-muted font-body">
            <time datetime={date.toISOString()}>{formattedDate}</time>
            {author && <span>by {author}</span>}
          </div>
        </header>
        <div class="prose prose-lg prose-green max-w-none font-body
                    prose-headings:font-heading prose-headings:text-forest
                    prose-a:text-leaf hover:prose-a:text-forest
                    prose-img:rounded-xl">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
